es":null,"display_name_styles":null,"banner_color":null,"clan":null,"primary_guild":null},"content":"yeah i think it will be necessary. like even to start an example. i live in a country now without these sorts of groups","timestamp":"2026-03-07T14:51:06.940000+00:00","edited_timestamp":null,"tts":false,"mention_everyone":false,"mentions":[],"attachments":[],"embeds":[],"pinned":false,"type":0,"flags":0,"components":[],"position":24,"userName":"ymsvz"},{"id":"1479853722447253504","channel_id":"1479847590035062825","author":{"id":"302973705452257281","username":"xorsense","avatar":"cb11971578a5b1dc733875667b838997","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"m3talsmith","avatar_decoration_data":null,"collectibles":null,"display_name_styles":{"font_id":8,"effect_id":3,"colors":[61695]},"banner_color":null,"clan":null,"primary_guild":null},"content":"There will be a set of users that never join a community too and that's one important reason to keep global dedicated nodes up. We'll have to figure out how to fund and organize that, but I think it will be a thing","timestamp":"2026-03-07T14:50:21.784000+00:00","edited_timestamp":null,"tts":false,"mention_everyone":false,"mentions":[],"attachments":[],"embeds":[],"pinned":false,"type":0,"flags":0,"components":[],"position":23,"userName":"xorsense"},{"id":"1479853575000690779","channel_id":"1479847590035062825","author":{"id":"1470753607325450271","username":"ymsvz","avatar":"22cca898691daf0b00d0d176406875d4","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"YMSVZ","avatar_decoration_data":null,"collectibles":null,"display_name_styles":null,"banner_color":null,"clan":null,"primary_guild":null},"content":"i think communities will be important, but dont think we should divide people by communities, they should be more or  less a club, that can help bring attention to users who often work together to projects","timestamp":"2026-03-07T14:49:46.630000+00:00","edited_timestamp":null,"tts":false,"mention_everyone":false,"mentions":[],"attachments":[],"embeds":[],"pinned":false,"type":0,"flags":0,"components":[],"position":22,"userName":"ymsvz"},{"id":"1479853347619078315","channel_id":"1479847590035062825","author":{"id":"302973705452257281","username":"xorsense","avatar":"cb11971578a5b1dc733875667b838997","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"m3talsmith","avatar_decoration_data":null,"collectibles":null,"display_name_styles":{"font_id":8,"effect_id":3,"colors":[61695]},"banner_color":null,"clan":null,"primary_guild":null},"content":"I think you underestimate how much community is going to matter here. Realistically I think that users will either be brought in through communities or quickly start forming their own","timestamp":"2026-03-07T14:48:52.418000+00:00","edited_timestamp":null,"tts":false,"mention_everyone":false,"mentions":[],"attachments":[],"embeds":[],"reactions":[{"emoji":{"id":null,"name":"👍"},"count":1,"count_details":{"burst":0,"normal":1},"burst_colors":[],"me_burst":false,"burst_me":false,"me":true,"burst_count":0}],"pinned":false,"type":0,"flags":0,"components":[],"position":21,"userName":"xorsense"},{"id":"1479852996182409468","channel_id":"1479847590035062825","author":{"id":"302973705452257281","username":"xorsense","avatar":"cb11971578a5b1dc733875667b838997","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"m3talsmith","avatar_decoration_data":null,"collectibles":null,"display_name_styles":{"font_id":8,"effect_id":3,"colors":[61695]},"banner_color":null,"clan":null,"primary_guild":null},"content":"So basically, it's a hybrid approach to resource storage, where the data can be split off to groups of nodes, instead of every node. It's not my ideal, but I'm thinking off the top of my head here","timestamp":"2026-03-07T14:47:28.629000+00:00","edited_timestamp":null,"tts":false,"mention_everyone":false,"mentions":[],"attachments":[],"embeds":[],"pinned":false,"type":0,"flags":0,"components":[],"position":20,"userName":"xorsense"},{"id":"1479852735322132592","channel_id":"1479847590035062825","author":{"id":"1470753607325450271","username":"ymsvz","avatar":"22cca898691daf0b00d0d176406875d4","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"YMSVZ","avatar_decoration_data":null,"collectibles":null,"display_name_styles":null,"banner_color":null,"clan":null,"primary_guild":null},"content":"because communities should more or less be optional groups, help people organize together but not be a necessity","timestamp":"2026-03-07T14:46:26.435000+00:00","edited_timestamp":null,"tts":false,"mention_everyone":false,"mentions":[],"attachments":[],"embeds":[],"pinned":false,"type":0,"flags":0,"components":[],"position":19,"userName":"ymsvz"},{"id":"1479852619861196981","channel_id":"1479847590035062825","author":{"id":"302973705452257281","username":"xorsense","avatar":"cb11971578a5b1dc733875667b838997","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"m3talsmith","avatar_decoration_data":null,"collectibles":null,"display_name_styles":{"font_id":8,"effect_id":3,"colors":[61695]},"banner_color":null,"clan":null,"primary_guild":null},"content":"They'd be joined to a global node then start to expand into communities. We'd have to engineer a path towards that.","timestamp":"2026-03-07T14:45:58.907000+00:00","edited_timestamp":null,"tts":false,"mention_everyone":false,"mentions":[],"attachments":[],"embeds":[],"pinned":false,"type":0,"flags":0,"components":[],"position":18,"userName":"xorsense"},{"id":"1479852409705599077","channel_id":"1479847590035062825","author":{"id":"1470753607325450271","username":"ymsvz","avatar":"22cca898691daf0b00d0d176406875d4","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"YMSVZ","avatar_decoration_data":null,"collectibles":null,"display_name_styles":null,"banner_color":null,"clan":null,"primary_guild":null},"content":"how would users who arent part of a community, connect with people just for projects, say i want to involve myself with some productive project while in china for a weekend, how do i connect to a local node to see what is happening locally","timestamp":"2026-03-07T14:45:08.802000+00:00","edited_timestamp":null,"tts":false,"mention_everyone":false,"mentions":[],"attachments":[],"embeds":[],"pinned":false,"type":0,"flags":0,"components":[],"position":17,"userName":"ymsvz"},{"id":"1479852263995605023","channel_id":"1479847590035062825","author":{"id":"302973705452257281","username":"xorsense","avatar":"cb11971578a5b1dc733875667b838997","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"m3talsmith","avatar_decoration_data":null,"collectibles":null,"display_name_styles":{"font_id":8,"effect_id":3,"colors":[61695]},"banner_color":null,"clan":null,"primary_guild":null},"content":"Think of the global platform as a federation of federations. It meets the reality of how things work on the ground.","timestamp":"2026-03-07T14:44:34.062000+00:00","edited_timestamp":null,"tts":false,"mention_everyone":false,"mentions":[{"id":"1470753607325450271","username":"ymsvz","avatar":"22cca898691daf0b00d0d176406875d4","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"YMSVZ","avatar_decoration_data":null,"collectibles":null,"display_name_styles":null,"banner_color":null,"clan":null,"primary_guild":null}],"attachments":[],"embeds":[],"pinned":false,"type":19,"message_reference":{"type":0,"channel_id":"1479847590035062825","message_id":"1479850166256271361","guild_id":"1474086812459860040"},"flags":0,"referenced_message":{"type":0,"content":"wouldnt that divide production along communities, in essence like nations?","mentions":[],"mention_roles":[],"attachments":[],"embed