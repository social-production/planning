position":8,"userName":"xorsense"},{"id":"1479468013114626059","channel_id":"1478902839651729500","author":{"id":"751276194594553867","username":"angeluvzzz","avatar":"bcdb2ee87e2c9ec68e3fb4ef100de5aa","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"luvz","avatar_decoration_data":null,"collectibles":null,"display_name_styles":null,"banner_color":null,"clan":null,"primary_guild":null},"content":"are we not using BFT?","timestamp":"2026-03-06T13:17:41.513000+00:00","edited_timestamp":null,"tts":false,"mention_everyone":false,"mentions":[{"id":"302973705452257281","username":"xorsense","avatar":"cb11971578a5b1dc733875667b838997","discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"m3talsmith","avatar_decoration_data":null,"collectibles":null,"display_name_styles":{"font_id":8,"effect_id":3,"colors":[61695]},"banner_color":null,"clan":null,"primary_guild":null}],"attachments":[],"embeds":[],"pinned":false,"type":19,"message_reference":{"type":0,"channel_id":"1478902839651729500","message_id":"1479067572862451765","guild_id":"1474086812459860040"},"flags":0,"referenced_message":{"type":0,"content":"A reputation system could work like this:\n\n- System defaults to only accepting a reputation weight of 100%\n- Reputation is tied to users and nodes\n- Bad actor gets a mark that lowers their reputation\n- All nodes at the default level take reputation into consideration when voting on blockchain - so if a bad actor has a change that would cause a fork, the bad actor loses the vote regardless of how many nodes they have\n\nEssentially, this guards against bad forks being introduced into the default network. But what happens if a user lowers the default threshold?\n\n- User and all of the nodes that they run get a reputation as low as the threshold they set\n- When a fork vote comes up, they lose the vote\n\nIt's a self balancing system that adjusts for bad actors.","mentions":[],"mentio